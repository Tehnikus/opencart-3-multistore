{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-tag-list').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="row">
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-tag-list">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td style="width: 70px" class="text-center">{{ column_image }}</td>
                      <td style="width: 200px;" class="text-left"><a href="{{ sort_name }}" {% if sort == 'name' %}class="{{ order|lower }}"{% endif %}>{{ column_name }}</a></td>
                      <td class="text-left"><a href="{{ sort_articles_count }}" {% if sort == 'articles_count' %}class="{{ order|lower }}"{% endif %}>{{ column_articles_count }}</a></td>
                      <td>{{ column_seo }}</td>
                      <td class="text-center" style="width: 60px"><a href="{{ sort_date_modified }}" {% if sort == 'date_modified' %}class="{{ order|lower }}"{% endif %}>{{ column_date_modified }}</a></td>
                      <td style="width: 60px"></td>
                    </tr>
                  </thead>
                  <tbody>
                    {% if items %}
                      {% for tag in items %}
                        <tr>
                          <td class="text-center"><input type="checkbox" name="selected[]" value="{{ tag.tag_id }}" {% if tag.tag_id in selected %}checked="checked"{% endif %} /></td>
                          <td class="text-center"><img class="img-thumbnail" src="{{ tag.image }}" loading="lazy"></td>
                          <td class="text-left"><b>{{ tag.name }}</b></td>
                          <td class="text-left">
                            {# <div>
                              {% for tag in tag.tags %}
                                <span class="badge badge-sm {% if tag.is_main == 1 %}strong alert-success{% endif %}">
                                  {{ tag.name }}
                                </span>
                                {% if tag.is_main == 1 %}<br>{% endif %}
                              {% endfor %}
                            </div> #}
                          </td>
                          <td>
                            <p>
                              <span class="badge badge-sm 
                                {% if tag.seo.descriptionLength > 2000 %} alert-success {% elseif tag.seo.descriptionLength > 500 %} alert-warning {% else %} alert-danger {% endif %}">
                                {{ text_description_length }}:&nbsp;{{ tag.seo.descriptionLength }}&nbsp;{{ text_characters_count }}
                                {% if tag.seo.descriptionLength > 500 %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>
                              <br>
                              <span class="badge badge-sm {% if tag.seo.hasFooter %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_footer }}:&nbsp;
                                {% if tag.seo.hasFooter %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if tag.seo.hasTag %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_tag }}:&nbsp;
                                {% if tag.seo.hasTag %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if tag.seo.hasFaq %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_faq }}:&nbsp;
                                {% if tag.seo.hasFaq %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if tag.seo.hasHowTo %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_how_to }}:&nbsp;
                                {% if tag.seo.hasHowTo %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>
                            </p>
                          </td>
                          <td class="text-center">{{ tag.date_modified }}</td>
                          <td>
                            {% if tag.status == '1' %}
                              <button class="btn btn-success statusBtn" data-tag-id="{{ tag.blog_tag_id }}" data-tag-status="{{ tag.status }}" type="button"><i class="fa fa-play"></i></button>
                            {% else %}
                              <button class="btn btn-danger statusBtn" data-tag-id="{{ tag.blog_tag_id }}" data-tag-status="{{ tag.status }}" type="button"><i class="fa fa-stop"></i></button>
                            {% endif %}
                          </td>
                          <td class="text-center"><a href="{{ tag.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                        </tr>
                      {% endfor %}
                    {% else %}
                      <tr><td class="text-center" colspan="7">{{ text_no_results }}</td></tr>
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{# Change order status btn #}
<script>
document.addEventListener('click', async e => {
  if (e.target.closest('.statusBtn')) {
    const userToken = "{{ user_token }}";
    const statusBtn = e.target.closest('.statusBtn');
    const tagId     = statusBtn.dataset.tagId
    const tagStatus = statusBtn.dataset.tagStatus
    const body      = new FormData();
    body.append('blog_tag_id', tagId);
    body.append('status', tagStatus);

    let response = await fetch(`index.php?route=blog/tag/fetchSetTagStatus&user_token=${userToken}`, {method: "POST", body}).then(r => r.json());
    if (response.newStatus === 1) {
      statusBtn.outerHTML = `<button class="btn btn-success statusBtn" data-tag-id="${tagId}" data-tag-status="${response.newStatus}" type="button"><i class="fa fa-play"></i></button>`;
    } else {
      statusBtn.outerHTML = `<button class="btn btn-danger statusBtn" data-tag-id="${tagId}" data-tag-status="${response.newStatus}" type="button"><i class="fa fa-stop"></i></button>`;
    }
  }
})
</script>
{{ footer }}
