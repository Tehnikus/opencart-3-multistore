<div class="modal-dialog" style="width: 1200px">
  <div class="modal-content">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
      <h4 class="modal-title"><i class="fa fa-cog"></i> {{ heading_title }}</h4>
    </div>
    <div class="modal-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <td>{{ column_component }}</td>
            <td style="width: 106px; text-align: center">{{ entry_cache }}</td>
            <td class="text-right" style="width: 1px;">{{ column_action }}</td>
          </tr>
        </thead>
       
        {% for key, settingValue in cacheSettings %}
          <tr>
            <td><b>{{ attribute(_context, 'entry_' ~ key) }}</b></td>
            <td>
              <div class="btn-group" data-toggle="buttons">
                <label class="btn btn-default {% if cacheSettings[key] == 1 %}active{% endif %}">
                  <input onchange="fetchSaveDeveloperSetting(this)" type="radio" name="{{ key }}" value="1" {% if cacheSettings[key] == '1' %}checked{% endif %}>
                  {{ button_on }}
                </label>
                <label class="btn btn-default {% if cacheSettings[key] == '0' %}active{% endif %}">
                  <input onchange="fetchSaveDeveloperSetting(this)" type="radio" name="{{ key }}" value="0" {% if cacheSettings[key] == '0' %}checked{% endif %}>
                  {{ button_off }}
                </label>
              </div>
            </td>
            <td>
              <button type="button" onclick="fetchClearData('{{ key }}')" title="{{ button_refresh }}" class="btn btn-danger"><i class="fa fa-trash"></i></button>
            </td>
          </tr>
        {% endfor %}
 

        
      </table>
    </div>
  </div>
</div>
<style>
  label.btn-default.active:has(input[value="1"]) {
    color: #fff;
    background-color: #3c933c;
    border-color: #2f722f;
    box-shadow: inset 0 3px 5px rgba(0, 0, 0, 0.125);
  }
  label.btn-default.active:has(input[value="0"]) {
    color: #fff;
    background-color: #d0321e;
    border-color: #a82818;
    box-shadow: inset 0 3px 5px rgba(0, 0, 0, 0.125);
  }
</style>
<script>
  function fetchSaveDeveloperSetting(e) {
    const body    = new FormData();
    const modal   = e.closest('.modal-dialog');
    const inputs  = modal.querySelectorAll('input[name^="developer"]:checked');
    inputs.forEach(input => {
      body.append(input.name, input.value);
    });
    fetch(`index.php?route=common/developer/edit&user_token={{ user_token }}`, {method: "POST", body})
    .then(r =>{ return r.json()})
    .then(r => {
      modal.querySelectorAll('.alert').forEach(e => {e.remove()});
      if (r.error) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i>${r.error.warning}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
      if (r.success) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-success alert-dismissible"><i class="fa fa-exclamation-circle"></i>${r.success}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
    })
  }

  function fetchClearData(key) {
    console.log(key)
  }
</script>


