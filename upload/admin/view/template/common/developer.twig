<div class="modal-dialog" style="width: 1200px">
  <div class="modal-content">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
      <h3 class="modal-title"><i class="fa fa-cog"></i> {{ entry_cache_settings }}: <b style="text-transform: capitalize">{{ cacheEngine }}</b></h3>
    </div>
    <div class="modal-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <td>{{ entry_cache_type }}</td>
            <td style="width: 105px"></td>
            <td style="width: 40px"></td>
          </tr>
        </thead>
        <tbody>
          {% for key, row in cacheSettings %}
            <tr>
              <td>{{ attribute(_context, 'developer_setting_' ~ key) }}</td>
              <td>
                {% if row.config is defined %}
                  <div class="btn-switch" style="display: flex">
                    <label>
                      <input onchange="fetchSaveDeveloperSetting(this)" type="radio" name="{{ row.config }}" value="1" {% if cacheSettings[key].configValue == '1' %}checked{% endif %}>
                      {{ option_on }}
                    </label>
                    <label>
                      <input onchange="fetchSaveDeveloperSetting(this)" type="radio" name="{{ row.config }}" value="0" {% if cacheSettings[key].configValue == '0' %}checked{% endif %}>
                      {{ option_off }}
                    </label>
                  </div>
                {% endif %}
              </td>
              <td>
                {% if row.path is defined %}
                  <button type="button" onclick="fetchClearData(this, '{{ key }}')" title="{{ button_refresh }}" class="btn btn-danger"><i class="fa fa-trash"></i></button>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
<style>
  .btn-switch {
    & input {
      display: none;
    }
    & label {
      color: #666;
      background-color: #fff;
      border: 1px solid #ddd;
      white-space: nowrap;
      padding: 8px 13px;
      cursor: pointer;
      &:first-child {
        border-radius: 3px 0 0 3px;
      }
      &:last-child {
        border-radius: 0 3px 3px 0;
      }
      &:not(:first-child) {
        border-left: none;
      }
      &:has(input[value="1"]:checked) {
        color: #fff;
        background-color: #3c933c;
        border-color: #2f722f;
      }
      &:has(input[value="0"]:checked) {
        color: #fff;
        background-color: #d0321e;
        border-color: #a82818;
      }
      &:hover {
        box-shadow: inset 0 0 6px #0003;
      }
    }
  }
</style>

<script>

  function fetchSaveDeveloperSetting(e) {
    const body    = new FormData();
    const modal   = e.closest('.modal-dialog');
    const inputs  = modal.querySelectorAll('input:checked');
    inputs.forEach(input => {
      body.append(input.name, input.value);
    });
    fetch(`index.php?route=common/developer/fetchEditCacheSettings&user_token={{ user_token }}`, {method: "POST", body})
    .then(r =>{ return r.json()})
    .then(r => {
      modal.querySelectorAll('.alert').forEach(e => {e.remove()});
      if (r.error) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ${r.error}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
      if (r.success) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-success alert-dismissible"><i class="fa fa-exclamation-circle"></i> ${r.success}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
    })
  }

  function fetchClearData(button, key) {
    const modal = button.closest('.modal-dialog');
    const body = new FormData();
    body.append('cacheType', key);
    fetch(`index.php?route=common/developer/fetchClearCache&user_token={{ user_token }}`, {method: "POST", body})
    .then(r =>{ return r.json()})
    .then(r => {
      modal.querySelectorAll('.alert').forEach(e => {e.remove()});
      if (r.error) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ${r.error}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
      if (r.success) {
        modal.querySelector('.modal-body').insertAdjacentHTML('afterbegin', `<div class="alert alert-success alert-dismissible"><i class="fa fa-exclamation-circle"></i> ${r.success}<button type="button" class="close" data-dismiss="alert">&times;</button></div>`)
      }
    });
  }

</script>