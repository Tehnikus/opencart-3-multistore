

<div class="panel panel-default">
  <div class="panel-body">
    <div class="col-sm-12 keywordGroups">
      <div class="input-group addKeywordGroupInput">
        <input class="form-control" type="text" placeholder="{{ input_add_keyword_group }}"/>
        <button class="btn btn-success addKeywordGroupBtn" type="button"><i class="fa fa-plus"></i></button>
      </div>
    </div>
  </div>
</div>

<ul class="nav nav-tabs" id="keywordsTabLanguage">
  {% for language in languages %}
    <li {% if loop.first %}class="active"{% endif %}>
      <a href="#keywords_language_{{ language.language_id }}" data-toggle="tab" data-tab-language-id="{{ language.language_id }}">
        <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> 
        <span>{{ tab_keywords }} {{ language.name }}
      </a>
    </li>
  {% endfor %}
</ul>
<div class="tab-content">
  {% for language in languages %}
    <div class="tab-pane {% if loop.first %}active{% endif %}" id="keywords_language_{{ language.language_id }}">
      <table class="table table-bordered table-hover table-striped">
        <thead>
          <tr>
            <td colspan="3"><h3 class="text-center">{{ tab_keywords }} {{ language.name }}</h3></td>
          </td>
          <tr>
            <td style="width: 50%">{{ column_seo_keyword }}</td>
            <td style="width: auto">{{ column_url }}</td>
            <td style="width: 140px; text-align: center"><button type="button" onclick="confirmDelete(this)" class="btn btn-danger" title="{{ remove_all_keywords }}"><i class="fa fa-trash"></i></button></td>
          </tr>
        </thead>
        <tbody>
        </tbody>
      </table>
    </div>
  {% endfor %}
</div>

  <div class="table-responsive tableWrapper">
    <table class="keywordTable table table-bordered table-hover">
    </table>
  </div>

{# Everything is done by nimbleTable.js and keywords.js #}
<script defer type="text/javascript" src="view/javascript/nimbleTable.js"></script>
<script defer type="text/javascript" src="view/javascript/keywords.js"></script>
<link href="view/stylesheet/nimbleTable.css" rel="stylesheet" />

<script>
  const user_token = "{{ user_token }}";
  const name_prefix = "{{ name_prefix }}";
  function confirmDelete(button) {
    if (!confirm("{{ confirm_remove_all_keywords }}")) {return}
    button.closest('table').tBodies[0].innerHTML = '';
  }
</script>

<style>
  .tableWrapper tr.updatedRow {
    background-color: #ffca7f7a;
    &:hover {
      background-color: #ffc16799
    }
  }
  .tableWrapper tr.newRow {
    background-color: #56d42840;
    &:hover {
      background-color: #56d42857
    }
  }

  .tableWrapper tr.importedRow {
    background-color: #316dc84a;
    &:hover {
      background-color: #316dc857;
    }
  }

  .keywordGroups {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
      & .keywordGroup {
      display: flex;
      border-radius: 5px;
      border: 1px solid #ddd;
      overflow: hidden;
      & span {
        align-self: center;
        padding: 0 1rem
      }
    }
  }

  [data-remove-row] {
    display: none!important;
  }
</style>