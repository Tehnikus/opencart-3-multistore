{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-filter" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid"> {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-filter" class="form-horizontal">
          <fieldset id="option-value">
            <legend>{{ text_group }}</legend>
            <div class="form-group required">
              <label class="col-sm-2 control-label">{{ entry_group }}</label>
              <div class="col-sm-10"> {% for language in languages %}
                <div class="input-group"><span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
                  <input type="text" name="filter_group_description[{{ language.language_id }}][name]" value="{{ filter_group_description[language.language_id] ? filter_group_description[language.language_id].name }}" placeholder="{{ entry_group }}" class="form-control" />
                </div>
                {% if error_group[language.language_id] %}
                <div class="text-danger">{{ error_group[language.language_id] }}</div>
                {% endif %}
                {% endfor %} </div>
            </div>
            <div class="form-group">
              <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
              <div class="col-sm-10">
                <input type="text" name="sort_order" value="{{ sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
              </div>
            </div>
          </fieldset>

          {# Store association #}
          <div class="form-group required">
            <label class="col-sm-2 control-label">{{ entry_store_association }}</label>
            <div class="col-sm-10">
              <div class="well well-sm" style="height: 150px; overflow: auto;"> 
                {% for store in stores %}
                  <div class="checkbox">
                    <label> 
                      <input type="checkbox" name="stores_association[]" value="{{ store.store_id }}" {% if store.store_id in stores_association or store.store_id == currentStore %} checked="checked" {% endif %} />
                      {{ store.name }}
                    </label>
                  </div>
                {% endfor %}
              </div>
              {% if error_store_association %}
                <div class="text-danger">{{ error_store_association }}</div>
              {% endif %}
            </div>
          </div>
          {# End store association #}

          <fieldset id="option-value">
            <legend>{{ text_value }}</legend>
            <table id="filter" class="table table-striped table-bordered table-hover">
              <thead>
                <tr>
                  <td class="text-left required">{{ entry_name }}</td>
                  <td class="text-right">{{ entry_sort_order }}</td>
                  <td></td>
                </tr>
              </thead>
              <tbody>
              
              {% set filter_row = 0 %}
              {% for filter in filters %}
              <tr id="filter-row{{ filter_row }}">
                <td class="text-center" style="width: auto"><input type="hidden" name="filter[{{ filter_row }}][filter_id]" value="{{ filter.filter_id }}" />
                  {% for language in languages %}
                    <div class="input-group">
                      <span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span>
                      {% include "common/button_create_seo_url.twig" with {seo_url_input: 'filter[' ~ filter_row ~ '][filter_description][' ~ language.language_id ~ '][url]' } %}
                      <input type="text" name="filter[{{ filter_row }}][filter_description][{{ language.language_id }}][name]"  value="{{ filter.filter_description[language.language_id].name }}"  placeholder="{{ entry_name }}"    class="form-control" />
                      <input type="text" name="filter[{{ filter_row }}][filter_description][{{ language.language_id }}][url]"   value="{{ filter.filter_description[language.language_id].url }}"   placeholder="{{ entry_keyword }}" class="form-control" />
                    </div>
                    {% if error_filter[filter_row][language.language_id] %}
                      <div class="text-danger">{{ error_filter[filter_row][language.language_id] }}</div>
                    {% endif %}
                    {% if error_url_not_unique[filter_row][language.language_id] %}
                      <div class="text-danger">{{ error_url_not_unique[filter_row][language.language_id] }}</div>
                    {% endif %}
                    {% if error_request_not_unique[filter_row][language.language_id] %}
                      <div class="text-danger">{{ error_request_not_unique[filter_row][language.language_id] }}</div>
                    {% endif %}
                  {% endfor %}
                </td>
                <td class="text-center" style="width: 100px"><input type="text" name="filter[{{ filter_row }}][sort_order]" value="{{ filter.sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control text-right" /></td>
                <td class="text-center" style="width: 60px"><button type="button" onclick="this.closest('tr').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
              </tr>
              {% set filter_row = filter_row + 1 %}
              {% endfor %}
                </tbody>
              
              <tfoot>
                <tr>
                  <td colspan="2"></td>
                  <td class="text-center"><button type="button" onclick="addFilterRow();" data-toggle="tooltip" title="{{ button_filter_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
                </tr>
              </tfoot>
            </table>
          </fieldset>
        </form>
      </div>
    </div>
  </div>
  <script>
    let filter_row = {{ filter_row }};

    function addFilterRow() {
      const languages = {{ languages|json_encode() }};
      const btnCreateUrl = `{% include "common/button_create_seo_url.twig" with {seo_url_input: 'filter[__filterRow__][filter_description][__langId__][url]' } %}`;
      html  = `<tr id="filter-row${filter_row}"><td class="text-center" style="width: auto"><input type="hidden" name="filter[${filter_row}][filter_id]" value="" />`;
      
      for (const key in languages) {
        const language = languages[key];
        let btn = btnCreateUrl;

        btn = btn.replace(/__filterRow__/g, filter_row);
        btn = btn.replace(/__langId__/g, language.language_id);

        html += `
          <div class="input-group">
            <span class="input-group-addon">
              <img src="language/${language.code}/${language.code}.png" title="${language.name}" />
            </span>
            ${btn}
            <input type="text" name="filter[${filter_row}][filter_description][${language.language_id}][name]" value="" placeholder="{{ entry_name }}" class="form-control" />
            <input type="text" name="filter[${filter_row}][filter_description][${language.language_id}][url]" value=""  placeholder="{{ entry_url }}" class="form-control" />
          </div>
        `;
      }
       
      html += `  
        </td>
        <td class="text-right" style="width: 100px">
          <input type="text" 
            name="filter[${filter_row}][sort_order]" 
            value="${filter_row + 1}" 
            placeholder="{{ entry_sort_order }}" 
            class="form-control text-right" />
        </td>
        <td class="text-right" style="width: 60px">
          <button type="button" 
            onclick="this.closest('tr').remove()" 
            title="{{ button_remove }}" 
            class="btn btn-danger">
            <i class="fa fa-minus-circle"></i>
          </button>
        </td>
        </tr>
      `;

      document.querySelector('#filter tbody').insertAdjacentHTML('beforeend', html);

      filter_row++;
    }

  </script>
</div>
{{ footer }} 