  document.addEventListener('DOMContentLoaded', () => {
    const editors = [];
    document.querySelectorAll('textarea.codeEditor').forEach(textarea => {
      const saveButton = textarea.closest('form').querySelector('button.saveCode');

      const editor = CodeMirror.fromTextArea(textarea, {
        mode: 'text/html',
        lineNumbers: true,
        theme: 'monokai'
      });

      editor.setSize('100%', '500px');
      editors.push(editor);

      saveButton.addEventListener('click', () => {
        const data = new FormData();
        data.append('code', editor.getValue());
        data.append('fileName', saveButton.dataset.filename);

        fetch(`index.php?route=design/css_editor/fetchSave&user_token=${userToken}`, {method: 'POST', body: data})
        .then(r => r.json())
        .then(r => {
          const messageBlock = document.querySelector('.editorMessage');
          messageBlock.classList.toggle('alert-success', r.success);
          messageBlock.classList.toggle('alert-danger', !r.success);
          messageBlock.innerHTML = `<p>${r.message}</p>`;
          messageBlock.style.display = '';
        });
      });
    });

    // refresh after tab open
    document.querySelectorAll('[data-toggle="tab"]').forEach(tab => {
      tab.addEventListener('click', () => {
        setTimeout(() => {
          editors.forEach(editor => editor.refresh());
        }, 0);
      });
    });
  });
</script>

<style>
  form .CodeMirror {
    height: 80vh;
    max-height: 80vh
  }
</style>

