{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {# Message #}
    <div style="display: none" class="editorMessage alert alert-dismissible"></div>

    <div class="row">
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_editor }}</h3>
          </div>
          <div class="panel-body">
            <ul class="nav nav-tabs" id="files">
              {% for file in files %}
                <li {% if loop.first %}class="active"{% endif %}>
                  <a href="#file_{{ file.name }}" data-toggle="tab">
                    <span>{{ file.name }}</span>
                  </a>
                </li>
              {% endfor %}
            </ul>
            <div class="tab-content">
              {% for file in files %}
                <div class="tab-pane {% if loop.first %}active{% endif %}" id="file_{{ file.name }}">
                  <form action="{{ save }}" method="post" enctype="multipart/form-data" id="form_{{ file.name }}">
                    <div class="row">
                      <button type="button" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-success saveCode"><i class="fa fa-floppy-o"></i> {{ button_save }}</button>
                    </div>
                    <div class="row">
                      <textarea name="{{ file.name }}" class="codeEditor">{{ file.code }}</textarea>
                    </div>
                  </form>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

