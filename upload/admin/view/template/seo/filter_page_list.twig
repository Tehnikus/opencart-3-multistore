{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form_filter_page_list').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="row">
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form_filter_page_list">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td style="width: 70px" class="text-center">{{ column_image }}</td>
                      <td style="width: 200px;" class="text-left"><a href="{{ sort_name }}" {% if sort == 'name' %}class="{{ order|lower }}"{% endif %}>{{ column_name }}</a></td>
                      <td class="text-left"><a href="{{ sort_category }}" {% if sort == 'category' %}class="{{ order|lower }}"{% endif %}>{{ column_category }}</a> / {{ column_filters }}</td>
                      <td>{{ column_seo }}</td>
                      <td class="text-center" style="width: 60px"><a href="{{ sort_product_count }}" {% if sort == 'product_count' %}class="{{ order|lower }}"{% endif %}>{{ column_product_count }}</a></td>
                      <td style="width: 60px"></td>
                    </tr>
                  </thead>
                  <tbody>
                    {% if items %}
                      {% for filter_page in items %}
                        <tr>
                          <td class="text-center"><input type="checkbox" name="selected[]" value="{{ filter_page.filter_page_id }}" {% if filter_page.filter_page_id in selected %}checked="checked"{% endif %} /></td>
                          <td class="text-center"><img class="img-thumbnail" src="{{ filter_page.image }}" loading="lazy"></td>
                          <td class="text-left"><b>{{ filter_page.name }}</b></td>
                          <td class="text-left">
                            <div>
                              {% for facet in filter_page.facets %}
                                <span class="badge badge-sm {% if facet.facet_type == 1 %}strong alert-success{% endif %}">
                                  {{ facet.name }}
                                  {% if facet.facet_type == 8 %}{{ autocomplete_is_available }}{% endif %}
                                  {% if facet.facet_type == 9 %}{{ autocomplete_has_discount }}{% endif %}
                                  {% if facet.facet_type == 10 %}{{ autocomplete_is_featured }}{% endif %}
                                </span>
                                {% if facet.facet_type == 1 %}<br>{% endif %}
                              {% endfor %}
                            </div>
                          </td>
                          <td>
                            <p>
                              <span class="badge badge-sm 
                                {% if filter_page.seo.descriptionLength > 2000 %} alert-success {% elseif filter_page.seo.descriptionLength > 500 %} alert-warning {% else %} alert-danger {% endif %}">
                                {{ text_description_length }}:&nbsp;{{ filter_page.seo.descriptionLength }}&nbsp;{{ text_characters_count }}
                                {% if filter_page.seo.descriptionLength > 500 %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>
                              <br>
                              <span class="badge badge-sm {% if filter_page.seo.hasFooter %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_footer }}:&nbsp;
                                {% if filter_page.seo.hasFooter %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if filter_page.seo.hasTag %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_tag }}:&nbsp;
                                {% if filter_page.seo.hasTag %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if filter_page.seo.hasFaq %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_faq }}:&nbsp;
                                {% if filter_page.seo.hasFaq %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>

                              <span class="badge badge-sm {% if filter_page.seo.hasHowTo %}alert-success{% else %}alert-danger{% endif %}">
                                {{ tab_how_to }}:&nbsp;
                                {% if filter_page.seo.hasHowTo %}<i class="fa fa-check"></i>{% else %}<i class="fa fa-times"></i>{% endif %}
                              </span>
                            </p>
                          </td>
                          <td class="text-center">{{ filter_page.product_count }}</td>
                          <td class="text-center"><a href="{{ filter_page.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                        </tr>
                      {% endfor %}
                    {% else %}
                      <tr><td class="text-center" colspan="4">{{ text_no_results }}</td></tr>
                    {% endif %}
                  </tbody>
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
