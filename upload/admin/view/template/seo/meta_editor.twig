{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ meta_editor }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {# {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %} #}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ header_formaulas }}</h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive">
          <form action="{{ fetchSaveFormulas }}" id="generateFormulas" method="post" enctype="multipart/form-data" class="fetchSaveForm">
            <table id="meta_editor_formulas" class="table table-bordered table-hover table-striped">
              <thead>
                <tr>
                  <td class="text-center">{{ column_formulas }}</td>
                  <td style="width: 50px"><button type="submit" form="generateFormulas" class="btn btn-warning" title="{{ button_save_all }}"><i class="fa fa-save"></i></button></td>
                </tr>
              </thead>
              <tbody>
                {% if formulas %}
                  {% for formula in formulas %}
                    <tr class="formula-row" data-row-index="{{ loop.index }}">
                      <td>
                        <div class="input-group flex">
                          <input value="{{ formula.generate_text }}" type="text" name="formulas[{{ loop.index }}][generate_text]" placeholder="{{placeholder_formula}}" class="form-control" />
                          <select class="form-control excludedInput" data-name="target_field" name="formulas[{{ loop.index }}][target_field]" value="{{formula.target_field}}">
                            {% for key, label in target_options %}
                              <option value="{{ key }}" {% if formula.target_field == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                          </select>
                          <select class="form-control excludedInput" data-name="language_id" name="formulas[{{ loop.index }}][language_id]">
                            {% for language in languages %}
                              <option value="{{ language.language_id }}" {% if formula.language_id == language.language_id %}selected{% endif %}>{{ language.name }}</option>
                            {% endfor %}
                          </select>
                          <select class="form-control excludedInput" data-name="currency_id" name="formulas[{{ loop.index }}][currency_id]">
                            {% for currency in currencies %}
                              <option value="{{ currency.currency_id }}" {% if formula.currency_id == currency.currency_id %}selected{% endif %}>{{ currency.title }}</option>
                            {% endfor %}
                          </select>
                          <button onclick="generateMeta(this)" type="button" class="flex flex-center btn btn-warning" title="{{ button_generate }}"><i class="fa fa-repeat"></i></button>
                        </div>
                      </td>
                      <td>
                        <button type="button" onclick="removeRow2(this, '#meta_editor_formulas', '[data-row-index]')" class="btn btn-danger remove_row" title="{{ button_remove_formula }}"><i class="fa fa-times"></i></button>
                      </td>
                    </tr>
                  {% endfor %}
                {% else %}
                  <tr class="formula-row" data-row-index="0">
                    <td>
                      <div class="input-group flex">
                        <input type="text" name="formulas[0][generate_text]" placeholder="{{ input_formula }}" class="form-control" />
                        <select class="form-control excludedInput" data-name="target_field" name="formulas[0][target_field]" style="min-width: 150px; max-width: 150px;">
                          {% for key, label in target_options %}
                            <option value="{{ key }}">{{ label }}</option>
                          {% endfor %}
                        </select>
                        <select class="form-control excludedInput" data-name="language_id" name="formulas[0][language_id]" style="min-width: 150px; max-width: 150px;">
                          {% for language in languages %}
                            <option value="{{ language.language_id }}">{{ language.name }}</option>
                          {% endfor %}
                        </select>
                        <select class="form-control excludedInput" data-name="currency_id" name="formulas[0][currency_id]" style="min-width: 150px; max-width: 150px;">
                          {% for currency in currencies %}
                            <option value="{{ currency.currency_id }}">{{ currency.title }}</option>
                          {% endfor %}
                        </select>
                        <button onclick="generateMeta(this)" type="button" class="flex flex-center btn btn-warning" title="{{ button_generate }}"><i class="fa fa-repeat"></i></button>
                      </div>
                    </td>
                    <td>
                      <button type="button" onclick="removeRow2(this, '#meta_editor_formulas')" class="btn btn-danger remove_row" title="{{ button_remove_formula }}"><i class="fa fa-times"></i></button>
                    </td>
                  </tr>
                {% endif %}
                <tr>
                  <td></td>
                  <td><button type="button" onclick="addRow2(this, '#meta_editor_formulas', '[data-row-index]', ['.excludedInput'])" class="btn btn-primary add_row" title="{{ button_add_formula }}"><i class="fa fa-plus-circle"></button></td>
                </tr>
              </tbody>
            </table>
            <div class="alert alert-info">
              <p>{{ help_syntax_hint }}</p>
              <br>
              <a data-toggle="collapse" href="#collapseInstruction" class="btn btn-primary">
                {{ help_show_manual }}
              </a>
              <div id="collapseInstruction" class="panel-collapse collapse">
                <div class="panel-body">
                  {{ help_syntax_example }}
                  <br>
                  {{ help_tag_hint }}
                </div>
              </div>
            </div>
            <div class="message message-success fixed"></div>
            <div class="message message-error fixed"></div>
          </form>
        </div>
      </div>
    </div>


    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ meta_editor }}</h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive tableWrapper">
          <table class="metaEditorTable table table-bordered table-hover table-striped">
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<script defer type="text/javascript" src="view/javascript/nimbleTable.js"></script>
<script defer type="text/javascript" src="view/javascript/batchloader.js"></script>
<script defer type="text/javascript" src="view/javascript/metaEditor.js"></script>
<script>
  const user_token = "{{ user_token }}";
  const pageType   = "{{ page_type }}";
  const columnId   = "{{ column_id }}";
</script>

<link href="view/stylesheet/nimbleTable.css" rel="stylesheet" />
<style>
  .tableWrapper {
    & .langData {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      & .langFlag {
        flex: 0 1 auto;
        align-content: center;
      }
      & .langSeoData {
        flex: 1 1 auto;
        flex-wrap: wrap;
        display: flex;
        & .seoInputs {
          display: flex;
          flex: 1 0 100%;
          flex-wrap: wrap;
          /* gap: 1rem; */
        }
        & .seoInputs .input-group {
          flex: 1 0 100%;
        }
      }
      & .seoBadges {
        flex: 1 0 100%;
        justify-content: center;
        display: flex;
        gap: 1rem;
      }
    }
  }
</style>

{{ footer }}