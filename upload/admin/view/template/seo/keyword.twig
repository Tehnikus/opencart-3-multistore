{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ keywords_list }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ keyword_groups }}</h3>
      </div>
      <div class="panel-body">
        <div id="keywordGroups" class="col-sm-12">
          <div id="addKeywordGroupInput" class="input-group col-sm-12">
            <input class="form-control" type="text" placeholder="{{ input_add_keyword_group }}"/><button id="addKeywordGroup" class="btn btn-success" type="button"><i class="fa fa-plus"></i></button>
          </div>
        </div>
      </div>
    </div>

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ keywords_list }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ form_action }}" method="post" enctype="multipart/form-data" id="form-filter" class="fetchSaveForm">
          <div class="table-responsive tableWrapper">
            <table id="keywordTable" class="keywordTable table table-bordered table-hover">
            </table>
          </div>
        </form>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script type="text/javascript" src="view/javascript/keywords.js"></script>
<script>
  const user_token = "{{ user_token }}";
</script>

<link href="view/stylesheet/nimbleTable.css" rel="stylesheet" />

<style>
  .tableWrapper tr.updatedRow {
    background-color: #ffca7f7a;
    &:hover {
      background-color: #ffc16799
    }
  }
  .tableWrapper tr.newRow {
    background-color: #56d42840;
    &:hover {
      background-color: #56d42857
    }
  }

  .tableWrapper tr.importedRow {
    background-color: #316dc84a;
    &:hover {
      background-color: #316dc857;
    }
  }

  #keywordGroups {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
      & .keywordGroup {
      display: flex;
      gap: 1rem;
      padding: 0 0 0 5px;
      border-radius: 5px;
      box-shadow: 0 0 3px #ccc;
      overflow: hidden;
    }
  }
</style>

{{ footer }}