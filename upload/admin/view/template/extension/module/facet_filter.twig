{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success_message %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success_message }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">

          {# Module status #}
          {# Should always have name module_" . $module_name . "_status to work #}
          <div class="form-group">
            <label class="col-sm-1 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-11">
              <select name="module_facet_filter_status" id="input-status" class="form-control">
                <option value="1" {% if module_facet_filter_status %} selected="selected" {% endif %}>{{ text_enabled }}</option>
                <option value="0" {% if not module_facet_filter_status %} selected="selected" {% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>

          {# Cache settings #}
          <div class="form-group">
            <label class="col-sm-1 control-label" for="input-status">{{ entry_cache }}</label>
            <div class="col-sm-11">
              <select name="module_facet_filter_settings[cache]" id="input-status" class="form-control">
                <option value="1" {% if settings.cache %} selected="selected" {% endif %}>{{ text_enabled }}</option>
                <option value="0" {% if not settings.cache %} selected="selected" {% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>

          {# Settings #}
          {# Define which filters to display #}
          <div class="form-group">
              <label class="col-sm-1 control-label" for="input-status">{{ text_edit }}</label>
              <div class="col-sm-11">
                <div class="table-responsive">
                  <table id="facetSettings" class="table table-bordered table-hover">
                    <thead>
                      <tr>
                        <td></td>
                        {% for facet in facetTypes %}
                          <td style="width: {{ 100 / (facetTypes|length + 3) }}%" class="text-center">{{ attribute(_context, 'facet_' ~ facet.facetType) }}</td>
                        {% endfor %}
                      </tr>
                    </thead>
                    <tbody id="settingsTable">
                      {% for pageType in pageTypes %}
                        <tr>
                          {# Title #}
                          <td>
                            <div class="pageType">
                              <b>{{ attribute(_context, 'page_' ~ pageType) }}</b>
                              <label for="{{ pageType }}_checkAll" style="float: right; font-weight: normal">{{ label_checkAll }}
                                <input type="checkbox" onchange="this.closest('tr').querySelectorAll('input[type=&quot;checkbox&quot;]').forEach(e => {e.checked = this.checked})" id="{{ pageType }}_checkAll" style="all: revert;">
                              </label>
                            </div>
                          </td>
                          {# Checkboxes #}
                          {% for facet in facetTypes %}
                            <td class="facetType">
                              <label for="{{ pageType }}_{{ facet.facetType }}">
                                <input id="{{ pageType }}_{{ facet.facetType }}" style="all: revert" type="checkbox" name="module_facet_filter_settings[{{ pageType }}][{{ facet.facetType }}]" value="1" {% if settings[pageType][facet.facetType] %} checked {% endif %} />
                              </label>
                            </td>
                          {% endfor %}
                        </tr>
                      {% endfor %}
                      
                      {# Individual category settings #}
                      <tr><td colspan="{{ facetTypes|length + 1}}" class="text-center"><b>{{ text_individual_categories }}</b></td></tr>
                      {% for id, category in settings.distinct_categories %}
                        <tr class="niftyItem" data-id="{{ id }}">
                          <td>
                            <div class="pageType">
                              <b>{{ category.name }}</b>
                              <div class="btn-group pull-right">
                                <a style="padding: 5px 8px;" class="btn btn-primary" target="_blank" href="/admin/index.php?route=catalog/category/edit&category_id={{ id }}&user_token={{ user_token }}"><i class="fa fa-pencil"></i></a>
                                <button style="padding: 5px 8px;" type="button" class="btn btn-danger niftyItemDelete" onclick="this.closest('.niftyItem').remove();"><i class="fa fa-times"></i></button>
                              </div>
                            </div>
                          </td>
                          {% for facet in facetTypes %}
                            <td class="facetType">
                              <label for="{{id}}_distinctCategory_{{ facet.facetType }}">
                                <input id="{{id}}_distinctCategory_{{ facet.facetType }}" style="all: revert" type="checkbox" name="module_facet_filter_settings[distinct_categories][{{ id }}][{{ facet.facetType }}]" value="1" {% if settings.distinct_categories[id][facet.facetType] %} checked {% endif %} />
                              </label>
                            </td>
                          {% endfor %}
                        </tr>
                      {% endfor %}
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="{{ facetTypes|length + 1}}">
                          <input id="categoryAutocomplete" type="text" class="form-control niftyAutocomplete" placeholder="{{ text_add_category }}" />
                        </td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
              </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Autocomplete
  document.addEventListener('DOMContentLoaded', () => {
    const userToken = "{{ user_token }}";
    const categoryInput = document.getElementById('categoryAutocomplete');

    const categoryAutocomplete = new niftyAutocomplete({
      input: categoryInput,
      selectedItemsBox: document.getElementById('settingsTable'),
      idKey: `category_id`,
      request: {
        url: `${location.protocol}${location.host}/admin/index.php?route=catalog/category/autocomplete`,
        getParams: {
          user_token: userToken,
          filter_name: () => categoryInput.value,
        }
      },
      item: {
        searchTemplate: (row) => `<div class="niftyItemData"><p><b>${row.name}</b></p></div>`,
        selectTemplate: (row) => `
          <tr>
            <td>
              <div class="pageType">
                <b>${row.name}</b>
                <div class="btn-group pull-right">
                  <a style="padding: 5px 8px;" class="btn btn-primary" target="_blank" href="/admin/index.php?route=catalog/category/edit&category_id=${row.category_id}&user_token=${userToken}"><i class="fa fa-pencil"></i></a>
                  <button style="padding: 5px 8px;" type="button" class="btn btn-danger niftyItemDelete"><i class="fa fa-times"></i></button>
                </div>
              </div>
            </td>
            {% for facet in facetTypes %}
              <td class="facetType">
                <label for="${row.category_id}_distinctCategory_{{ facet.facetType }}">
                  <input id="${row.category_id}_distinctCategory_{{ facet.facetType }}" style="all: revert" type="checkbox" name="module_facet_filter_settings[distinct_categories][${row.category_id}][{{ facet.facetType }}]" value="1" checked />
                </label>
              </td>
            {% endfor %}
          </tr>
        `,
      },
      behavior: {
        clearSearchOnSelect: true,
      }
    });
  });
</script>

<style>
table#facetSettings {
  td {
    padding: 0;
    height: 43px;
    .pageType {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5px;
    }
    label {
      height: 43px;
      margin: 0;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    &.facetType label:has(input:checked) {
      background: #1e91cf10;
    }
  }
}
</style>
{{ footer }}
