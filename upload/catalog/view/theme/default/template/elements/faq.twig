{% if faq %}
  <span class="h3">{{ tab_faq }}</span>
  {% for item in faq.mainEntity %}
    <details>
      <summary role="button">
        <h5>{{ item.name }}</h5>
      </summary>
      <div class="content">
        {{ item.acceptedAnswer.text}}
      </div>
    </details>
  {% endfor %}
{% endif %}